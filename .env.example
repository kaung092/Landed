# Copy this file to `.env` and fill in the values you need. `.env` is gitignored.

# --- Asset root -----------------------------------------------------------
# The folder the app reads/writes and that the Claude "CoWork" agent works in:
# your base résumé, tailored-resume folders, the tailor queue, and the
# instruction .md files that brief CoWork. Defaults to ./asset-root in the repo.
ASSET_ROOT=./asset-root
# Where the CoWork instruction .md files live. Defaults to $ASSET_ROOT/instructions.
# INSTRUCTIONS_ROOT=./asset-root/instructions

# --- Database -------------------------------------------------------------
# SQLite file — the single source of truth. Defaults to data/jobhunt.db.
# DB_PATH=data/jobhunt.db

# --- Anthropic ------------------------------------------------------------
# Read automatically by @anthropic-ai/sdk if any server-side Claude calls run.
# Most agentic work happens through Claude CoWork over the MCP server instead.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Optional -------------------------------------------------------------
# Base URL the MCP server uses to reach the running app. Defaults to http://localhost:3000.
# JOBHUNT_URL=http://localhost:3000
# Database backups (scripts/backup-db.mjs).
# BACKUP_DIR=data/backups
# BACKUP_KEEP=60
# One-off inbox reconcile script (scripts/reconcile-inbox.mjs).
# INBOX_AUDIT_CSV=data/inbox-audit.csv