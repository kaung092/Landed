{
  "name": "landed",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "seed:prep": "tsx scripts/seed-prep.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "prep:export": "node --env-file-if-exists=.env --import tsx scripts/export-prep-context.ts",
    "import:prep": "tsx scripts/import-prep-progress.ts",
    "diagram:arch": "tsx scripts/gen-architecture-diagram.ts",
    "diagram:pipeline": "tsx scripts/gen-pipeline-diagram.ts",
    "backup": "node scripts/backup-db.mjs",
    "purge:nonlocal": "tsx scripts/purge-nonlocal.ts",
    "tailor:docx": "node --import tsx scripts/tailor-docx.ts",
    "levels:scrape": "node scripts/levels-scrape.mjs",
    "test": "node --import tsx --test tests/*.test.ts",
    "check": "npm run typecheck && npm test",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^173.0.0",
    "imapflow": "^1.4.3",
    "lucide-react": "^1.21.0",
    "mailparser": "^3.9.12",
    "mammoth": "^1.12.0",
    "next": "16.2.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dependency-cruiser": "^17.4.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "overrides": {
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2",
    "@emnapi/wasi-threads": "1.2.2",
    "postcss": "8.5.22",
    "sharp": "0.35.3"
  }
}
