# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local sqlite db
/data/

# Caddy's local data/certs if it ever writes into the repo (root-owned; keep it out of the
# Tailwind/Turbopack content scan, which can't read a root-only dir → build 500s)
/caddy/

# Machine-specific local serving config (hardcoded absolute paths — not portable)
/scripts/landed.Caddyfile
/scripts/com.kaung.landed-proxy.plist

# Claude Code local (personal, uncommitted) settings
.claude/settings.local.json
